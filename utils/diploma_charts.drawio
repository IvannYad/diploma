        <mxCell id="ky-oa1lLef4rxpHJpedi-116" edge="1" parent="1" source="ky-oa1lLef4rxpHJpedi-104" style="endArrow=open;dashed=1;html=1;rounded=0;fontSize=10;edgeStyle=orthogonalEdgeStyle;" target="ky-oa1lLef4rxpHJpedi-99" value="logs stages">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="2710" y="-422" />
