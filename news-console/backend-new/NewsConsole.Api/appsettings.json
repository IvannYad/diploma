{
  "Mongo": {
    "DatabaseName": "diploma"
  },
  "ConnectionStrings": {
    "Identity": "Server=(localdb)\\MSSQLLocalDB;Database=diploma;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Processing": {
    "CompletionWebhookEndpoint": "http://localhost:5000/api/webhooks/processing/completed",
    "DockerApiPort": 2375,
    "OpenAiApiKey": "",
    "ModelName": "gpt-4o-mini",
    "PipelineDockerImage": "news-pipeline:latest",
    "OlapRebuildDockerImage": "olap-schema-rebuild-pipeline:latest"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning",
      "NewsConsole": "Debug",
      "NewsConsole.Api.Controllers.PipelineController": "Trace"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:5000"
}
